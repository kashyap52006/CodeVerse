# Environment Variables Template for CodeVerse
# Copy this file to .env and fill in your values
# NEVER commit your actual .env file to version control

# ─────────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────────
# For production (PostgreSQL):
DATABASE_URL="postgresql://username:password@localhost:5432/codeverse"

# For local development (SQLite — simpler setup):
# DATABASE_URL="file:./dev.db"

# ─────────────────────────────────────────────
# JWT AUTHENTICATION
# ─────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="replace-this-with-a-secure-random-string-min-32-chars"
JWT_EXPIRY="24h"

# ─────────────────────────────────────────────
# GOOGLE OAUTH 2.0
# ─────────────────────────────────────────────
# Get these from: https://console.cloud.google.com/
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_CALLBACK_URL="http://localhost:3001/api/auth/google/callback"

# ─────────────────────────────────────────────
# EMAIL (SMTP) — For Password Reset
# ─────────────────────────────────────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-gmail-app-password"
EMAIL_FROM="CodeVerse <your-email@gmail.com>"

# ─────────────────────────────────────────────
# SERVER
# ─────────────────────────────────────────────
PORT=3001
CLIENT_URL="http://localhost:5173"
NODE_ENV="development"

# ─────────────────────────────────────────────
# CODE EXECUTION LIMITS
# ─────────────────────────────────────────────
EXECUTION_TIMEOUT_SECONDS=5
EXECUTION_MEMORY_MB=128
EXECUTION_CPU_LIMIT=0.5
MAX_CODE_SIZE_KB=64
